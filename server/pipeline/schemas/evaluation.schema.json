{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pagecraft.local/schemas/evaluation.schema.json",
  "title": "PageCraft Evaluation / Repair Ticket",
  "description": "Veredicto do Evaluator/Judge; quando pass=false funciona como repair-ticket com routing explícito",
  "type": "object",
  "required": ["pass", "severity", "issues"],
  "additionalProperties": true,
  "properties": {
    "pass": {
      "type": "boolean",
      "description": "Decisão final: true = página aprovada"
    },
    "route": {
      "type": "string",
      "description": "Para onde vai a reparação quando pass=false",
      "enum": ["builder", "designer", "architect", "both"]
    },
    "severity": {
      "type": "string",
      "description": "Severidade agregada",
      "enum": ["low", "medium", "high", "critical"]
    },
    "issues": {
      "type": "array",
      "description": "Problemas encontrados",
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["low", "medium", "high", "critical"]
              },
              "location": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        ]
      }
    },
    "required_fixes": {
      "type": "array",
      "description": "Correções obrigatórias para a próxima iteração",
      "items": { "type": "string" }
    },
    "acceptance_checks": {
      "type": "array",
      "description": "Critérios observáveis que a correção deve satisfazer",
      "items": { "type": "string" }
    },
    "evidence": {
      "type": "array",
      "description": "Evidência recolhida (snapshot, consola, interações testadas)",
      "items": { "type": "string" }
    },
    "blocked_by": {
      "type": "array",
      "description": "Bloqueios externos que impedem a avaliação/correção",
      "items": { "type": "string" }
    }
  },
  "if": {
    "properties": { "pass": { "const": false } }
  },
  "then": {
    "required": ["route"]
  }
}
